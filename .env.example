# ============================================================
# Cheewarun (ชีวารุณ) — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env
# ============================================================

# ===== App =====
APP_ENV=production
APP_NAME=Cheewarun
DOMAIN=cheewarun.duckdns.org
NEXT_PUBLIC_API_URL=https://cheewarun.duckdns.org/api
NEXT_PUBLIC_WS_URL=wss://cheewarun.duckdns.org/ws

# ===== Database (Postgres + TimescaleDB) =====
POSTGRES_USER=cheewarun
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=cheewarun_db
DATABASE_URL=postgresql+asyncpg://cheewarun:CHANGE_ME_STRONG_PASSWORD@db:5432/cheewarun_db
DATABASE_URL_SYNC=postgresql://cheewarun:CHANGE_ME_STRONG_PASSWORD@db:5432/cheewarun_db

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== Security (JWT) =====
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_32_CHARS_RANDOM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== Web Push (VAPID) =====
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
VAPID_PUBLIC=GENERATE_ME
VAPID_PRIVATE=GENERATE_ME
VAPID_SUBJECT=mailto:plaiad.innovation@gmail.com
NEXT_PUBLIC_VAPID_PUBLIC=SAME_AS_VAPID_PUBLIC

# ===== MQTT =====
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_USER=cheewarun_server
MQTT_PASS=CHANGE_ME

# ===== AI Providers (Auto-fallback: OpenAI → Gemini → Claude) =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ===== CORS =====
CORS_ORIGINS=["https://cheewarun.duckdns.org"]
